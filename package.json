{
  "name": "quickoutline",
  "version": "3.0.0-pre",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/document/*",
    "packages/shared-kit"
  ],
  "scripts": {
    "dev": "vite dev",
    "dev:allnet": "vite dev --host",
    "build": "bun run copy:assets && bun run build:outline-parser-cli && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "copy:katex": "bun scripts/copy-katex-assets.mjs",
    "copy:pagedjs": "bun scripts/copy-pagedjs.mjs",
    "copy:pdfjs": "bun scripts/copy-pdfjs.mjs",
    "copy:assets": "bun run copy:katex && bun run copy:pagedjs && bun run copy:pdfjs",
    "build:outline-parser-cli": "bun scripts/build-outline-parser-cli.mjs",
    "build:unocss": "bun scripts/build-unocss-runtime.mjs"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.0",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.11.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.8",
    "@lezer/common": "^1.4.0",
    "@lezer/highlight": "^1.2.3",
    "@lezer/markdown": "^1.6.1",
    "@mdx-js/mdx": "^3.1.1",
    "@milkdown/core": "^7.17.2",
    "@milkdown/ctx": "^7.17.2",
    "@milkdown/plugin-history": "^7.17.2",
    "@milkdown/plugin-listener": "^7.17.2",
    "@milkdown/plugin-math": "^7.5.9",
    "@milkdown/preset-commonmark": "^7.17.2",
    "@milkdown/preset-gfm": "^7.17.2",
    "@milkdown/prose": "^7.17.2",
    "@milkdown/theme-nord": "^7.17.2",
    "@milkdown/utils": "^7.17.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "2.9.0",
    "@tauri-apps/plugin-dialog": "2.4.2",
    "@tauri-apps/plugin-fs": "2.4.4",
    "@tauri-apps/plugin-opener": "2.5.2",
    "@tauri-apps/plugin-shell": "2.3.3",
    "@types/markdown-it": "^14.1.2",
    "@uiw/codemirror-theme-github": "^4.25.3",
    "codemirror": "^6.0.2",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.27",
    "markdown-it": "^14.1.0",
    "markdown-it-abbr": "^2.0.0",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-bracketed-spans": "^1.0.1",
    "markdown-it-container": "^4.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-texmath": "^1.0.0",
    "outline-parser": "workspace:*",
    "pagedjs": "^0.4.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.449",
    "shared-kit": "workspace:*",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.18.0",
    "@mdx-js/rollup": "^3.1.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tauri-apps/cli": "2.9.4",
    "@tsconfig/svelte": "^5.0.8",
    "@types/css-font-loading-module": "^0.0.14",
    "@types/node": "^25.7.0",
    "@unocss/preset-wind": "^66.6.8",
    "@unocss/runtime": "^66.6.8",
    "download": "^3.3.0",
    "esbuild": "^0.28.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "tslib": "^2.0.0",
    "typescript": "^6.0.3",
    "unocss": "^66.6.8",
    "vite": "^8.0.12",
    "vite-plugin-static-copy": "^4.1.0"
  }
}
