{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "allowArbitraryExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "outline-parser": ["packages/document/outline-parser/src/index.ts"],
      "outline-parser/*": ["packages/document/outline-parser/src/*"],
      "shared-kit": ["packages/shared-kit/src/index.ts"],
      "shared-kit/*": ["packages/shared-kit/src/*"]
    },
    "types": ["vite/client"],
    "jsx": "react",
    "jsxFactory": "createElement",
    "jsxFragmentFactory": "Fragment",
    "allowImportingTsExtensions": true
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.svelte",
    "src/**/*.tsx",
    "packages/document/outline-parser/src/**/*.d.ts",
    "packages/document/outline-parser/src/**/*.ts",
    "packages/document/outline-parser/src/**/*.js",
    "packages/shared-kit/src/**/*.d.ts",
    "packages/shared-kit/src/**/*.ts",
    "packages/shared-kit/src/**/*.js",
    "packages/shared-kit/src/**/*.svelte"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
