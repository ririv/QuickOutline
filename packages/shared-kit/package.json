{
  "name": "shared-kit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./controls/*": {
      "svelte": "./src/controls/*",
      "default": "./src/controls/*"
    },
    "./actions/*": {
      "types": "./src/actions/*.ts",
      "default": "./src/actions/*.ts"
    }
  },
  "peerDependencies": {
    "svelte": "^5.45.2"
  }
}
